{
  "name": "@jeromefitz/websites",
  "version": "0.0.0",
  "description": "Monorepo for series of websites for Jerome Fitzgerald (he/him).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeromefitz/websites"
  },
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=24.14.0 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "clean:install": "TURBO_TELEMETRY_DISABLED=1 turbo run clean && ./scripts/clean.sh",
    "format": "pnpm format:biome:write && pnpm format:prettier:write",
    "format:biome:base": "biome format",
    "format:biome:check": "pnpm format:biome:base",
    "format:biome:write": "pnpm format:biome:base --write",
    "format:prettier:base": "prettier \"./**/package.json\" \"**.{html,md,mdx,yml,yaml}\" \"!pnpm-lock.yaml\" --ignore-unknown",
    "format:prettier:check": "pnpm format:prettier:base --check",
    "format:prettier:write": "pnpm format:prettier:base --write",
    "lint": "pnpm run lint:biome && pnpm run format:prettier:check && pnpm run lint:packages",
    "lint:biome": "biome lint",
    "lint:packages": "syncpack lint",
    "preinstall": "npx only-allow pnpm",
    "prepare": "pnpm is-ci || pnpm dlx husky@9.1.7",
    "semantic-release": "pnpm run semantic-release:mono",
    "semantic-release:dry": "pnpm semantic-release:mono --dry-run",
    "semantic-release:mono": "pnpm --filter jeromefitzgerald.com -r --workspace-concurrency=1 exec -- npx --no-install semantic-release",
    "turbo": "TURBO_TELEMETRY_DISABLED=1 turbo"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.4.8",
    "@jeromefitz/conventional-gitmoji": "5.0.0",
    "@jeromefitz/prettier-config": "3.0.1",
    "@jeromefitz/release-notes-generator": "4.0.0",
    "@jeromefitz/semantic": "12.0.2",
    "@jeromefitz/tsconfig": "3.0.0",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.0",
    "ccommit": "4.0.1",
    "dotenv": "17.3.1",
    "is-ci": "4.1.0",
    "lodash-es": "4.17.23",
    "node-modules-inspector": "1.4.2",
    "publint": "0.3.18",
    "semantic-release": "25.0.3",
    "syncpack": "14.2.0",
    "ts-node": "10.9.2",
    "tsdown": "0.21.4",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@semantic-release/commit-analyzer@13.0.1": "patches/@semantic-release__commit-analyzer@13.0.0.patch"
    },
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "@babel/core": "^7.28.4",
      "@babel/helpers": "^7.28.4",
      "@babel/runtime": "^7.28.4",
      "@octokit/plugin-paginate-rest": "^14.0.0",
      "@semantic-release/npm": "^13.1.5",
      "brace-expansion@^1.0.0": "1.1.12",
      "cross-spawn": "^7.0.6",
      "diff": "^8.0.0",
      "elliptic": "^6.6.1",
      "esbuild": "^0.27.4",
      "flatted": "^3.4.2",
      "h3": "^1.15.9",
      "js-yaml": "^4.1.1",
      "micromatch": "^4.0.8",
      "nanoid@^3.0.0": "^3.3.8",
      "pbkdf2": "^3.1.3",
      "preact": "^10.26.10",
      "semver@^5.0.0": "^5.7.2",
      "semver@^6.0.0": "^6.3.1",
      "semver@^7.0.0": "^7.7.3",
      "sha.js": "^2.4.12",
      "ws": "^8.18.0"
    },
    "supportedArchitectures": {
      "os": [
        "darwin",
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  }
}
